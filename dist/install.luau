	["H"] = { "#.#", "#.#", "###", "#.#", "#.#" },
	["I"] = { "###", ".#.", ".#.", ".#.", "###" },
	["J"] = { "..#", "..#", "..#", "#.#", "###" },
	["K"] = { "#.#", "#.#", "##.", "#.#", "#.#" },
