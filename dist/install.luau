	["/"] = { "..#", "..#", ".#.", "#..", "#.." },
	["="] = { "...", "###", "...", "###", "..." },
	["<"] = { "..#", ".#.", "#..", ".#.", "..#" },
	[">"] = { "#..", ".#.", "..#", ".#.", "#.." },
	["%"] = { "#.#", "..#", ".#.", "#..", "#.#" },
	["*"] = { "...", "#.#", ".#.", "#.#", "..." },
