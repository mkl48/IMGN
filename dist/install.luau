-- with this; Canvas only ever calls through these methods.
export type Driver = {
	Mount: (self: any, parent: Instance) -> Frame,
	SetDirty: (self: any, index: number) -> (),
	SetAllDirty: (self: any) -> (),
	Flush: (self: any) -> (),
	Destroy: (self: any) -> (),
}

