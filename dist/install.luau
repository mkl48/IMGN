	PixelGrid = PixelGrid.new :: any,
	RowMerge = RowMerge.new :: any,
	GreedyMesh = GreedyMesh.new :: any,
	RichText = RichText.new :: any,
	Blob = Blob.new :: any,
	Sparse = Sparse.new :: any,
