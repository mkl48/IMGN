-- Bakes a local image file into a Luau ModuleScript so you can load it with NO link / no
-- HttpService at runtime - the bytes ship inside your place.
--
--   lune run scripts/embed-image <path/to/cat.png> [out.luau]
--
-- The generated module just `return`s the file bytes as a string. Drop it under
-- ReplicatedStorage, then:
--
--   local bytes = require(ReplicatedStorage.CatPng)
--   local canvas = IMGN.ImageCanvas(bytes, { Parent = surfaceGui, Format = "PNG" })

local fs = require("@lune/fs")
local process = require("@lune/process")

local input = process.args[1]
if not input then
	print("usage: lune run scripts/embed-image <image-file> [out.luau]")
	process.exit(1)
end

local output = process.args[2] or (input:gsub("%.%w+$", "") .. ".luau")

local data = fs.readFile(input) -- binary string
-- string.format("%q") emits a valid Luau string literal that round-trips arbitrary bytes
-- (quotes/backslashes/control chars all escaped), so the module reloads the file exactly.
local literal = string.format("%q", data)

local module = table.concat({
	`-- Generated by scripts/embed-image.luau from "{input}" ({#data} bytes). Do not edit by hand.`,
	"-- require this and pass the result to IMGN.ImageCanvas / Canvas:LoadImage.",
	"return " .. literal .. "\n",
}, "\n")

fs.writeFile(output, module)
print(`Wrote {output} ({#data} bytes embedded).`)
